{
  "author": "Kevin Ross <kevin.ross@alienfast.com>",
  "auto": {
    "canary": {
      "target": "comment"
    },
    "plugins": [
      [
        "npm",
        {
          "setRcToken": false
        }
      ],
      "all-contributors",
      "first-time-contributor",
      "released"
    ]
  },
  "devDependencies": {
    "@alienfast/biome-config": "^1.0.4",
    "@alienfast/logger": "workspace:*",
    "@alienfast/tsconfig": "^1.0.8",
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@biomejs/biome": "^2.3.8",
    "@lerna-lite/changed": "^4.9.4",
    "@lerna-lite/cli": "^4.9.4",
    "@lerna-lite/exec": "^4.9.4",
    "@lerna-lite/list": "^4.9.4",
    "@lerna-lite/publish": "^4.9.4",
    "@lerna-lite/version": "^4.9.4",
    "@types/babel__core": "^7",
    "@types/node": "^24.10.1",
    "@types/rimraf": "^4",
    "@vitejs/plugin-react": "^5.1.1",
    "auto": "^11.3.6",
    "execa": "^9.6.0",
    "madge": "^8.0.0",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "tsdown": "^0.16.8",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@11.9.0",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": "https://github.com/alienfast/logger",
  "scripts": {
    "build": "run-s clean build-prep build-each",
    "build-each": "lerna exec --stream -- pnpm build",
    "build-prep": "lerna exec --stream -- cp ../../.npmignore . && lerna exec --stream -- cp ../../LICENSE .",
    "check": "run-p -c --aggregate-output check-types check-biome check-circular check-markdown test",
    "check-biome": "biome check --write",
    "check-circular": "madge --circular --extensions ts ./packages/*/src --ts-config ./tsconfig.json",
    "check-markdown": "markdownlint-cli2 --fix \"**/*.md\"",
    "check-types": "tsc -p tsconfig.json",
    "clean": "tsx ./scripts/clean.ts",
    "clean-deps": "tsx ./scripts/clean-deps.ts",
    "lint-fix": "run-s check-biome check-markdown",
    "release": "auto shipit",
    "reset": "tsx ./scripts/reset.ts",
    "test": "vitest run"
  },
  "type": "module",
  "version": "11.0.7"
}
